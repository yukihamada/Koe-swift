{
  "manifest_version": 3,
  "name": "Koe Voice Input",
  "version": "1.0.0",
  "description": "Voice input with AI — click to start Koe voice recognition",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Start Voice Input (Koe)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": [],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  }
}
